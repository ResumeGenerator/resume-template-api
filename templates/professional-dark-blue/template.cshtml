@using ResumeTemplateService.Domain.ValueObjects
@model ResumeViewModel
@{
    var snapshotItems = new List<string>();
    if (Model.CareerSnapshot.YearsOfExperience > 0) snapshotItems.Add($"{Model.CareerSnapshot.YearsOfExperience}+ years");
    if (!string.IsNullOrWhiteSpace(Model.CareerSnapshot.CareerLevel)) snapshotItems.Add(Model.CareerSnapshot.CareerLevel);
    if (!string.IsNullOrWhiteSpace(Model.CareerSnapshot.Industry)) snapshotItems.Add(Model.CareerSnapshot.Industry);
    if (!string.IsNullOrWhiteSpace(Model.CareerSnapshot.Specialization)) snapshotItems.Add(Model.CareerSnapshot.Specialization);
    var highlights = Model.TechnicalHighlights.Concat(Model.LeadershipHighlights).Concat(Model.ProjectHighlights).Concat(Model.IndustryHighlights).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().Take(8).ToList();
}
<div style="font-family: 'Segoe UI', Arial, sans-serif; color: #172033; background: #edf3f8; padding: 18px; line-height: 1.42;">
    <div style="max-width: 816px; margin: 0 auto; background: #ffffff; box-shadow: 0 18px 44px rgba(15, 23, 42, 0.18); border: 1px solid #cbd7e4; overflow: hidden;">
        <div style="background: #17376d; color: #ffffff; padding: 32px 40px 24px; border-bottom: 5px solid #d7a82f;">
            <div style="font-size: 33px; line-height: 1.08; font-weight: 850;">@Model.PersonalInfo.FullName</div>
            @if (!string.IsNullOrWhiteSpace(Model.Headline))
            {
                <div style="margin-top: 8px; max-width: 700px; color: #dce7f5; font-size: 14px; font-weight: 550;">@Model.Headline</div>
            }
            <div style="display: flex; flex-wrap: wrap; gap: 8px 16px; margin-top: 15px; font-size: 12px; color: #f8fafc;">
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.Email)) { <a style="color: #ffd66b; text-decoration: none; font-weight: 750;" href="mailto:@Model.PersonalInfo.Email">@Model.PersonalInfo.Email</a> }
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.Phone)) { <span>@Model.PersonalInfo.Phone</span> }
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.Location)) { <span>@Model.PersonalInfo.Location</span> }
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.LinkedInUrl)) { <a style="color: #ffd66b; text-decoration: none; font-weight: 750;" href="@Model.PersonalInfo.LinkedInUrl" target="_blank">LinkedIn</a> }
            </div>
            @if (snapshotItems.Any() || Model.CareerSnapshot.FocusAreas.Any())
            {
                <div style="margin-top: 14px; padding: 10px 12px; background: rgba(255,255,255,0.09); border: 1px solid rgba(255,255,255,0.22); font-size: 11px; color: #f8fafc;">
                    @if (snapshotItems.Any()) { <div style="font-weight: 850; color: #ffffff;">@string.Join(" | ", snapshotItems)</div> }
                    @if (Model.CareerSnapshot.FocusAreas.Any()) { <div style="margin-top: 4px; color: #dce7f5;">Focus: @string.Join(", ", Model.CareerSnapshot.FocusAreas.Take(8))</div> }
                </div>
            }
        </div>

        <div style="padding: 27px 40px 36px;">
            @if (Model.SummaryPoints.Any())
            {
                <section style="margin-bottom: 20px;">
                    <div style="background: #17376d; color: #ffffff; border-left: 5px solid #d7a82f; padding: 8px 12px; font-size: 12px; font-weight: 850; text-transform: uppercase; margin-bottom: 10px;">Professional Summary</div>
                    @foreach (var point in Model.SummaryPoints.Take(5))
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 5px; font-size: 12px; color: #263244;"><span style="color: #b8891d; font-weight: 900;">&bull;</span><span>@point</span></div>
                    }
                </section>
            }

            @if (Model.SkillGroups.Any())
            {
                <section style="margin-bottom: 20px;">
                    <div style="background: #17376d; color: #ffffff; border-left: 5px solid #d7a82f; padding: 8px 12px; font-size: 12px; font-weight: 850; text-transform: uppercase; margin-bottom: 10px;">Skills & Platforms</div>
                    @foreach (var group in Model.SkillGroups.Take(4))
                    {
                        <div style="margin-bottom: 8px;">
                            <span style="display: inline-block; min-width: 128px; font-size: 11px; font-weight: 850; color: #17376d;">@group.Name</span>
                            <span style="font-size: 11px; color: #334155;">@string.Join(", ", group.Skills.Take(14))</span>
                        </div>
                    }
                </section>
            }

            @if (highlights.Any())
            {
                <section style="margin-bottom: 20px;">
                    <div style="background: #17376d; color: #ffffff; border-left: 5px solid #d7a82f; padding: 8px 12px; font-size: 12px; font-weight: 850; text-transform: uppercase; margin-bottom: 10px;">Selected Highlights</div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px 18px;">
                        @foreach (var highlight in highlights)
                        {
                            <div style="display: flex; gap: 7px; font-size: 11px; color: #334155;"><span style="color: #b8891d; font-weight: 900;">&bull;</span><span>@highlight</span></div>
                        }
                    </div>
                </section>
            }

            @if (Model.Experience.Any())
            {
                <section style="margin-bottom: 20px;">
                    <div style="background: #17376d; color: #ffffff; border-left: 5px solid #d7a82f; padding: 8px 12px; font-size: 12px; font-weight: 850; text-transform: uppercase; margin-bottom: 10px;">Professional Experience</div>
                    @foreach (var exp in Model.Experience.Take(6))
                    {
                        <div style="margin-bottom: 13px; padding-bottom: 11px; border-bottom: 1px solid #e3eaf2;">
                            <div style="display: flex; justify-content: space-between; gap: 14px; align-items: baseline;">
                                <div style="font-size: 13px; font-weight: 850; color: #17376d;">@exp.JobTitle</div>
                                <div style="font-size: 11px; color: #667085; white-space: nowrap;">@exp.DateRange</div>
                            </div>
                            <div style="font-size: 12px; color: #263244; font-weight: 750;">@exp.Company@if (!string.IsNullOrWhiteSpace(exp.Location)) { <span style="color: #667085; font-weight: 500;"> - @exp.Location</span> }</div>
                            @foreach (var achievement in exp.Achievements.Take(3))
                            {
                                <div style="display: flex; gap: 8px; margin-top: 4px; font-size: 11px; color: #334155;"><span style="color: #b8891d; font-weight: 900;">&bull;</span><span>@achievement</span></div>
                            }
                            @if (exp.Technologies.Any())
                            {
                                <div style="margin-top: 5px; font-size: 10px; color: #667085;"><span style="font-weight: 850; color: #17376d;">Tech:</span> @string.Join(", ", exp.Technologies.Take(12))</div>
                            }
                        </div>
                    }
                </section>
            }

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                @if (Model.Education.Any())
                {
                    <section>
                        <div style="background: #17376d; color: #ffffff; border-left: 5px solid #d7a82f; padding: 8px 12px; font-size: 12px; font-weight: 850; text-transform: uppercase; margin-bottom: 10px;">Education</div>
                        @foreach (var edu in Model.Education.Take(2))
                        {
                            <div style="margin-bottom: 10px;"><div style="font-size: 12px; font-weight: 850; color: #17376d;">@edu.Degree</div><div style="font-size: 11px; color: #263244;">@edu.Institution</div><div style="font-size: 11px; color: #667085;">@edu.FieldOfStudy @edu.DateRange</div></div>
                        }
                    </section>
                }
                @if (Model.Certifications.Any())
                {
                    <section>
                        <div style="background: #17376d; color: #ffffff; border-left: 5px solid #d7a82f; padding: 8px 12px; font-size: 12px; font-weight: 850; text-transform: uppercase; margin-bottom: 10px;">Certifications</div>
                        @foreach (var cert in Model.Certifications.Take(5))
                        {
                            <div style="font-size: 11px; color: #334155; margin-bottom: 6px;"><span style="font-weight: 850; color: #17376d;">@cert.Name</span>@if (!string.IsNullOrWhiteSpace(cert.Issuer)) { <span style="color: #667085;"> - @cert.Issuer</span> }</div>
                        }
                    </section>
                }
            </div>
        </div>
    </div>
</div>
