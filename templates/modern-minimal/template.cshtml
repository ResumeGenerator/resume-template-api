@using ResumeTemplateService.Domain.ValueObjects
@model ResumeViewModel
@{
    var snapshotItems = new List<string>();
    if (Model.CareerSnapshot.YearsOfExperience > 0) snapshotItems.Add($"{Model.CareerSnapshot.YearsOfExperience}+ years");
    if (!string.IsNullOrWhiteSpace(Model.CareerSnapshot.CareerLevel)) snapshotItems.Add(Model.CareerSnapshot.CareerLevel);
    if (!string.IsNullOrWhiteSpace(Model.CareerSnapshot.Industry)) snapshotItems.Add(Model.CareerSnapshot.Industry);
    if (!string.IsNullOrWhiteSpace(Model.CareerSnapshot.Specialization)) snapshotItems.Add(Model.CareerSnapshot.Specialization);
    var highlights = Model.TechnicalHighlights.Concat(Model.LeadershipHighlights).Concat(Model.ProjectHighlights).Concat(Model.IndustryHighlights).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().Take(8).ToList();
}
<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; color: #1f2937; background: #eef3f8; padding: 18px; line-height: 1.42;">
    <div style="max-width: 816px; margin: 0 auto; background: #ffffff; box-shadow: 0 16px 38px rgba(31, 41, 55, 0.14); border: 1px solid #dbe4ee;">
        <div style="padding: 30px 38px 20px; border-bottom: 3px solid #d8e2ec; background: #fbfcfe;">
            <div style="font-size: 33px; line-height: 1.05; font-weight: 850; color: #111827;">@Model.PersonalInfo.FullName</div>
            @if (!string.IsNullOrWhiteSpace(Model.Headline))
            {
                <div style="margin-top: 8px; font-size: 14px; font-weight: 650; color: #334155;">@Model.Headline</div>
            }
            <div style="display: flex; flex-wrap: wrap; gap: 8px 16px; margin-top: 13px; font-size: 12px; color: #334155;">
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.Email)) { <a style="color: #0f5f9e; text-decoration: none; font-weight: 700;" href="mailto:@Model.PersonalInfo.Email">@Model.PersonalInfo.Email</a> }
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.Phone)) { <span>@Model.PersonalInfo.Phone</span> }
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.Location)) { <span>@Model.PersonalInfo.Location</span> }
                @if (!string.IsNullOrWhiteSpace(Model.PersonalInfo.LinkedInUrl)) { <a style="color: #0f5f9e; text-decoration: none; font-weight: 700;" href="@Model.PersonalInfo.LinkedInUrl" target="_blank">LinkedIn</a> }
            </div>
            @if (snapshotItems.Any() || Model.CareerSnapshot.FocusAreas.Any())
            {
                <div style="margin-top: 14px; padding: 10px 12px; background: #edf5fb; border: 1px solid #cfe0ef; font-size: 11px; color: #263244;">
                    @if (snapshotItems.Any())
                    {
                        <div style="font-weight: 800; color: #111827;">@string.Join(" | ", snapshotItems)</div>
                    }
                    @if (Model.CareerSnapshot.FocusAreas.Any())
                    {
                        <div style="margin-top: 4px;">Focus: @string.Join(", ", Model.CareerSnapshot.FocusAreas.Take(8))</div>
                    }
                </div>
            }
        </div>

        <div style="padding: 24px 38px 34px;">
            @if (Model.SummaryPoints.Any())
            {
                <section style="margin-bottom: 19px;">
                    <div style="font-size: 12px; font-weight: 850; color: #111827; text-transform: uppercase; border-bottom: 1px solid #d8e2ec; padding-bottom: 7px; margin-bottom: 9px;">Professional Summary</div>
                    @foreach (var point in Model.SummaryPoints.Take(5))
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 5px; font-size: 12px; color: #374151;"><span style="color: #0f5f9e; font-weight: 900;">&bull;</span><span>@point</span></div>
                    }
                </section>
            }

            @if (Model.SkillGroups.Any())
            {
                <section style="margin-bottom: 19px;">
                    <div style="font-size: 12px; font-weight: 850; color: #111827; text-transform: uppercase; border-bottom: 1px solid #d8e2ec; padding-bottom: 7px; margin-bottom: 9px;">Skills & Tools</div>
                    @foreach (var group in Model.SkillGroups.Take(4))
                    {
                        <div style="margin-bottom: 8px;">
                            <span style="display: inline-block; min-width: 120px; font-size: 11px; font-weight: 850; color: #111827;">@group.Name</span>
                            <span style="font-size: 11px; color: #374151;">@string.Join(", ", group.Skills.Take(14))</span>
                        </div>
                    }
                </section>
            }

            @if (highlights.Any())
            {
                <section style="margin-bottom: 19px;">
                    <div style="font-size: 12px; font-weight: 850; color: #111827; text-transform: uppercase; border-bottom: 1px solid #d8e2ec; padding-bottom: 7px; margin-bottom: 9px;">Selected Highlights</div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px 18px;">
                        @foreach (var highlight in highlights)
                        {
                            <div style="display: flex; gap: 7px; font-size: 11px; color: #374151;"><span style="color: #0f5f9e; font-weight: 900;">&bull;</span><span>@highlight</span></div>
                        }
                    </div>
                </section>
            }

            @if (Model.Experience.Any())
            {
                <section style="margin-bottom: 19px;">
                    <div style="font-size: 12px; font-weight: 850; color: #111827; text-transform: uppercase; border-bottom: 1px solid #d8e2ec; padding-bottom: 7px; margin-bottom: 9px;">Professional Experience</div>
                    @foreach (var exp in Model.Experience.Take(6))
                    {
                        <div style="margin-bottom: 12px;">
                            <div style="display: flex; justify-content: space-between; gap: 14px; align-items: baseline;">
                                <div style="font-size: 13px; font-weight: 850; color: #111827;">@exp.JobTitle</div>
                                <div style="font-size: 11px; color: #64748b; white-space: nowrap;">@exp.DateRange</div>
                            </div>
                            <div style="font-size: 12px; color: #334155; font-weight: 700;">@exp.Company@if (!string.IsNullOrWhiteSpace(exp.Location)) { <span style="color: #64748b; font-weight: 500;"> - @exp.Location</span> }</div>
                            @foreach (var achievement in exp.Achievements.Take(3))
                            {
                                <div style="display: flex; gap: 8px; margin-top: 4px; font-size: 11px; color: #374151;"><span style="color: #0f5f9e; font-weight: 900;">&bull;</span><span>@achievement</span></div>
                            }
                            @if (exp.Technologies.Any())
                            {
                                <div style="margin-top: 5px; font-size: 10px; color: #64748b;"><span style="font-weight: 800; color: #475569;">Tech:</span> @string.Join(", ", exp.Technologies.Take(12))</div>
                            }
                        </div>
                    }
                </section>
            }

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                @if (Model.Education.Any())
                {
                    <section>
                        <div style="font-size: 12px; font-weight: 850; color: #111827; text-transform: uppercase; border-bottom: 1px solid #d8e2ec; padding-bottom: 7px; margin-bottom: 9px;">Education</div>
                        @foreach (var edu in Model.Education.Take(2))
                        {
                            <div style="margin-bottom: 10px;"><div style="font-size: 12px; font-weight: 850; color: #111827;">@edu.Degree</div><div style="font-size: 11px; color: #334155;">@edu.Institution</div><div style="font-size: 11px; color: #64748b;">@edu.FieldOfStudy @edu.DateRange</div></div>
                        }
                    </section>
                }
                @if (Model.Certifications.Any())
                {
                    <section>
                        <div style="font-size: 12px; font-weight: 850; color: #111827; text-transform: uppercase; border-bottom: 1px solid #d8e2ec; padding-bottom: 7px; margin-bottom: 9px;">Certifications</div>
                        @foreach (var cert in Model.Certifications.Take(5))
                        {
                            <div style="font-size: 11px; color: #374151; margin-bottom: 6px;"><span style="font-weight: 850; color: #111827;">@cert.Name</span>@if (!string.IsNullOrWhiteSpace(cert.Issuer)) { <span style="color: #64748b;"> - @cert.Issuer</span> }</div>
                        }
                    </section>
                }
            </div>
        </div>
    </div>
</div>
